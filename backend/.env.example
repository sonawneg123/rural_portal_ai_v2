# ============================================================
# RURAL PORTAL BACKEND — Environment Variables
# Copy to .env and fill in real values
# For Railway: add these in the Variables tab
# ============================================================

# ── Server ────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# Frontend origin for CORS (Vercel URL or custom domain)
FRONTEND_URL=https://your-project.vercel.app

# ── JWT ───────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace_with_96_hex_chars_from_command_above
JWT_EXPIRES_IN=7d

# ── MySQL (PlanetScale / Railway MySQL / AWS RDS) ─────────────
DB_HOST=your-db-host.railway.internal
DB_PORT=3306
DB_NAME=rural_portal
DB_USER=root
DB_PASSWORD=your_db_password
DB_POOL_SIZE=10
# Set to true only for PlanetScale (which requires SSL)
DB_SSL=false

# ── AWS S3 (photo uploads) ────────────────────────────────────
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
S3_BUCKET_NAME=rural-portal-photos

# ── Groq AI API ───────────────────────────────────────────────
# Free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama3-8b-8192

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info
